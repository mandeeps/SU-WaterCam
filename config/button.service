[Unit]
Description=Python script to perform an action on button press - like taking photos

[Service]
User=pi
Group=pi
Type=idle
WorkingDirectory=/home/pi/SU-WaterCam
ExecStart=/home/pi/SU-WaterCam/venv/bin/python3 /home/pi/SU-WaterCam/button-service-gpiozero.py

[Install]
WantedBy=multi-user.target
